{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "issue-ledger.schema.json",
  "title": "IssueLedger",
  "description": "Tracks all issues raised during a workflow run, including their lifecycle and decisions.",
  "type": "object",
  "required": ["run_id", "issues"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Issue"
      }
    }
  },
  "$defs": {
    "Issue": {
      "type": "object",
      "required": ["id", "round", "raised_by", "severity", "description", "evidence", "status", "repeat_count"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ISS-\d{3,}$",
          "description": "Issue ID, e.g. ISS-001"
        },
        "round": {
          "type": "integer",
          "minimum": 1,
          "description": "Round number when first raised"
        },
        "raised_by": {
          "type": "string",
          "enum": ["codex", "claude", "human"]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "description": {
          "type": "string"
        },
        "evidence": {
          "type": "string",
          "description": "Section reference or evidence location"
        },
        "status": {
          "type": "string",
          "enum": ["open", "accepted", "rejected", "deferred", "resolved"]
        },
        "decided_by": {
          "type": "string",
          "enum": ["claude", "human"]
        },
        "decision_reason": {
          "type": "string"
        },
        "resolved_in_round": {
          "type": "integer",
          "minimum": 1
        },
        "repeat_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Times re-raised after rejection (for deadlock detection)"
        }
      }
    }
  }
}
