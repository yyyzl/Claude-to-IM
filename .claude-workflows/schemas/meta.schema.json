{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meta.schema.json",
  "title": "WorkflowMeta",
  "description": "Metadata for a workflow run, including status, configuration, and checkpoint info.",
  "type": "object",
  "required": ["run_id", "workflow_type", "status", "current_round", "current_step", "created_at", "updated_at", "config"],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "workflow_type": {
      "type": "string",
      "enum": ["spec-review", "dev", "code-review"]
    },
    "status": {
      "type": "string",
      "enum": ["running", "paused", "completed", "failed", "human_review"]
    },
    "current_round": {
      "type": "integer",
      "minimum": 0
    },
    "current_step": {
      "type": "string",
      "enum": ["codex_review", "issue_matching", "pre_termination", "claude_decision", "post_decision"],
      "description": "Fine-grained step state for crash-safe resume"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "config": {
      "$ref": "#/$defs/WorkflowConfig"
    },
    "last_completed": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["round", "step"],
          "properties": {
            "round": { "type": "integer", "minimum": 0 },
            "step": {
              "type": "string",
              "enum": ["codex_review", "issue_matching", "pre_termination", "claude_decision", "post_decision"]
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "WorkflowConfig": {
      "type": "object",
      "required": ["max_rounds", "auto_terminate", "human_review_on_deadlock", "codex_timeout_ms", "claude_timeout_ms", "codex_max_retries", "claude_max_retries", "codex_context_window_tokens", "context_files"],
      "properties": {
        "max_rounds": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "auto_terminate": {
          "type": "boolean",
          "default": true
        },
        "human_review_on_deadlock": {
          "type": "boolean",
          "default": true
        },
        "codex_timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 180000
        },
        "claude_timeout_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 120000
        },
        "codex_max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "claude_max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "codex_context_window_tokens": {
          "type": "integer",
          "minimum": 1000,
          "default": 128000
        },
        "context_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "content"],
            "properties": {
              "path": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
